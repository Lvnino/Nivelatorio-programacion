Algoritmo miPrimerPrograma
	definir x Como Entero
	Imprimir "ingrese un numero"
	Leer x
	Mientras x>0 Hacer
		si x MOD 2==0  Entonces
			Imprimir "x es par"
		SiNo 
			imprimir "x es impar"
		Fin Si
		Imprimir "ingrese el numero"
		leer x
	FinMientras
	Imprimir "numero ingresado fue menor o igual a 0"
FinAlgoritmo
